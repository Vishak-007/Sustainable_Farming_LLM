# ==========================================
# 🌿 Smart Farmer Backend Environment Config
# ==========================================

# 1. Server Configuration
# The port that the Express server will listen on
PORT=5000

# 2. Database Connection
# Replace with your MongoDB Atlas Connection String
# Example: mongodb+srv://<username>:<password>@cluster0.mongodb.net/agrofarmers
# Fallback local testing string: mongodb://localhost:27017/agrofarmers
MONGO_URI=mongodb://localhost:27017/agrofarmers

# 3. Third-Party API Keys
# Data.gov.in API key for fetching real-time Mandi crop prices
# Register at https://data.gov.in to get an API key
DATA_GOV_API_KEY=your_data_gov_api_key_here
